#!/bin/bash
# terraform-credentials-keychain: Terraform credentials helper backed by macOS Keychain.
#
# Implements the Terraform credentials helper protocol so that tokens for
# Terraform Enterprise / HCP Terraform hostnames are stored in and retrieved
# from the macOS Keychain rather than plain-text ~/.terraform.d/credentials.tfrc.json.
#
# Protocol reference:
#   https://developer.hashicorp.com/terraform/internals/credentials-helpers
#
# Usage: terraform-credentials-keychain <get|store|forget> <hostname>

# -e  exit immediately on error
# -u  treat unbound variables as errors
# -o pipefail  propagate pipeline failures
set -euo pipefail

# Keychain service name used as the namespace for all stored tokens.
SERVICE="terraform-credentials"

usage() {
  echo "Usage: ${0} [get|store|forget] hostname" >&2
  exit 1
}

# Require exactly two arguments: <command> and <hostname>.
if [[ ${#} -ne 2 ]]; then
  usage
fi

COMMAND="${1}"
# Use "TFE_HOSTNAME" rather than HOSTNAME to avoid shadowing bash's built-in $HOSTNAME.
TFE_HOSTNAME="${2}"

case "${COMMAND}" in
  get)
    ret=0
    # -w returns only the password value; 2>&1 captures error text for re-display.
    token=$(security -q find-generic-password -s "${SERVICE}" -a "${TFE_HOSTNAME}" -w 2>&1) || ret=$?

    if [[ ${ret} -eq 44 ]]; then
      # Exit code 44 ("errSecItemNotFound") means no token is stored for this
      # hostname. Respond with an empty credentials object per the protocol.
      echo "{}"
      exit 0
    elif [[ ${ret} -ne 0 ]]; then
      # Any other non-zero exit from security(1) is a genuine error; surface it.
      echo "${token}" >&2
      exit "${ret}"
    fi

    # Emit the token as a well-formed JSON credentials object.
    cat <<EOF
{
    "token": "${token}"
}
EOF
    ;;

  store)
    # Terraform pipes a JSON object to stdin; extract the token field.
    # The jq expression returns empty (→ empty string) if the object has any
    # key other than "token", so we can detect an unsupported format below.
    token=$(jq -r 'if keys == ["token"] then .token else empty end')
    if [[ -z ${token} ]]; then
      echo "Unknown credentials object format" >&2
      exit 2
    fi
    # -U updates an existing Keychain entry instead of failing if one exists.
    security -q add-generic-password -U -s "${SERVICE}" -a "${TFE_HOSTNAME}" -w "${token}"
    ;;

  forget)
    ret=0
    # Suppress output; we handle both the success and "not found" cases below.
    security -q delete-generic-password -s "${SERVICE}" -a "${TFE_HOSTNAME}" >/dev/null 2>&1 || ret=$?
    if [[ ${ret} -ne 0 && ${ret} -ne 44 ]]; then
      # Ignore exit code 44 ("errSecItemNotFound") — the credential is already
      # absent, which is the desired post-condition of forget. Fail on anything else.
      exit "${ret}"
    fi
    ;;

  *)
    usage
    ;;
esac
